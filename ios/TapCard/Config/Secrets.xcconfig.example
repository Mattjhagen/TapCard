// Copy this file to Secrets.xcconfig and fill in your Supabase project's values.
// Secrets.xcconfig is gitignored - never commit real keys (see the root .env incident
// this repo already had to clean up).
SUPABASE_PROJECT_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-anon-public-key
